# Bootstrap credentials for the Infisical CLI — NOT application secrets.
# These only let the CLI authenticate to Infisical; all real secrets
# (MONGO_URI, etc.) live in Infisical and are fetched at runtime.
#
# Usage (local dev):
#   cp .env.bootstrap.example .env.bootstrap   # .env.bootstrap is gitignored
#   # fill the values below, then:
#   source .env.bootstrap
#   export INFISICAL_TOKEN=$(infisical login --method=universal-auth \
#     --client-id=$INFISICAL_CLIENT_ID --client-secret=$INFISICAL_CLIENT_SECRET \
#     --plain --silent)
#   make dev    # docker compose interpolates INFISICAL_API_URL + INFISICAL_TOKEN

# Self-hosted Infisical base URL (note the /api suffix).
INFISICAL_API_URL=https://<infisical-host>/api

# Machine Identity (Universal Auth) credentials.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
