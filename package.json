{
  "name": "csat-server",
  "version": "0.1.0",
  "private": true,
  "description": "CSAT backend — service-based monorepo (api, worker, scheduler)",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build --dry || tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "infisical run --projectId=$INFISICAL_PROJECT_ID --env=dev -- env MONGO_DB_NAME=csat_test vitest run --coverage",
    "dev:api": "infisical run --projectId=$INFISICAL_PROJECT_ID --env=dev -- npm run dev -w @csat/api",
    "dev:worker": "infisical run --projectId=$INFISICAL_PROJECT_ID --env=dev -- npm run dev -w @csat/worker",
    "dev:scheduler": "infisical run --projectId=$INFISICAL_PROJECT_ID --env=dev -- npm run dev -w @csat/scheduler"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.9"
  }
}
