{
  "name": "csat-server",
  "version": "0.1.0",
  "private": true,
  "description": "CSAT backend — service-based monorepo (api, worker, scheduler)",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --build --dry || tsc -b",
    "dev:api": "npm run dev -w @csat/api",
    "dev:worker": "npm run dev -w @csat/worker",
    "dev:scheduler": "npm run dev -w @csat/scheduler"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
