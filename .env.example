# Secrets are managed in Infisical — NOT in .env files.
# The app reads these keys from process.env, populated at boot by `infisical run`.
# This file documents the keys only; set their VALUES in the Infisical project
# (per environment: dev / staging / prod).
#
# To authenticate the CLI locally, see .env.bootstrap.example.

# --- Auth / JWT ---
# Signing secrets for access & refresh tokens. REQUIRED — generate strong,
# distinct random values per environment, e.g. `openssl rand -base64 48`.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Token lifetimes (optional). Any jsonwebtoken `expiresIn` string.
# Defaults: JWT_ACCESS_TTL=15m, JWT_REFRESH_TTL=30d
JWT_ACCESS_TTL=
JWT_REFRESH_TTL=

# --- Security ---
# Password pepper for additional hashing security. REQUIRED — generate a strong
# random value that remains consistent across the application lifecycle.
# e.g. `openssl rand -base64 32`
PASSWORD_PEPPER=

