# Secrets are managed in Infisical — NOT in .env files.
# The app reads these keys from process.env, populated at boot by `infisical run`.
# This file documents ALL keys the application reads; set their VALUES in the
# Infisical project (per environment: dev / staging / prod).
#
# To authenticate the CLI locally, see .env.bootstrap.example.
#
# REQUIRED keys will cause the process to crash at startup if missing.
# OPTIONAL keys have hard-coded defaults shown in comments.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Node environment. Affects log format (JSON in prod, pretty in dev) and
# whether stack traces are included in API error responses.
# Optional — default: development
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database — MongoDB
# ---------------------------------------------------------------------------

# Full MongoDB connection string. REQUIRED.
# Format: mongodb://[user:password@]host[:port][/database][?options]
# e.g.  mongodb://localhost:27017/csat                   (local dev, no auth)
#       mongodb+srv://user:pass@cluster.mongodb.net/csat  (Atlas)
MONGO_URI=

# MongoDB database name.
# Optional — default: csat
MONGO_DB_NAME=csat

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------

# TCP port the Express API server listens on.
# Optional — default: 4000
API_PORT=4000

# ---------------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------------

# Signing secrets for access & refresh tokens. REQUIRED.
# Generate strong, distinct random values per environment:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (any jsonwebtoken `expiresIn` string).
# Optional — defaults: JWT_ACCESS_TTL=15m, JWT_REFRESH_TTL=30d
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Password pepper — mixed into every password hash via HMAC-SHA256 before
# bcrypt. REQUIRED. Must stay constant for the lifetime of the database.
# Generate once:  openssl rand -base64 32
PASSWORD_PEPPER=

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------

# How often (in milliseconds) the worker polls for new jobs.
# Optional — default: 5000
WORKER_POLL_INTERVAL_MS=5000

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------

# How often (in milliseconds) the scheduler evaluates due schedules.
# Optional — default: 10000
SCHEDULER_TICK_INTERVAL_MS=10000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Winston log level. Optional.
# Defaults: "info" in production, "debug" in all other environments.
# Valid values: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=
