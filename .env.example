# ---- Shared ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- MongoDB ----
# In docker-compose the host is the service name `mongo`.
MONGO_URI=mongodb://mongo:27017/csat
MONGO_DB_NAME=csat

# ---- API service ----
API_PORT=4000

# ---- Worker service ----
WORKER_POLL_INTERVAL_MS=5000

# ---- Scheduler service ----
SCHEDULER_TICK_INTERVAL_MS=10000
